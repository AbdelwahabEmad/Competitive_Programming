/*
CSES - Monsters

Time limit: 1.00 s
Memory limit: 512 MB

You and some monsters are in a labyrinth. When taking a step to some direction in the labyrinth, each monster may simultaneously take one as well. Your goal is to reach one of the boundary squares without ever sharing a square with a monster.
Your task is to find out if your goal is possible, and if it is, print a path that you can follow. Your plan has to work in any situation; even if the monsters know your path beforehand.
Input
The first input line has two integers nnn and mmm: the height and width of the map.
After this there are nnn lines of mmm characters describing the map. Each character is . (floor), # (wall), A (start), or M (monster). There is exactly one A in the input.
Output
First print "YES" if your goal is possible, and "NO" otherwise.
If your goal is possible, also print an example of a valid path (the length of the path and its description using characters D, U, L, and R). You can print any path, as long as its length is at most n⋅mn \cdot mn⋅m steps.
Constraints

1≤n,m≤10001 \le n,m \le 10001≤n,m≤1000

Example
Input:
5 8
########
#M..A..#
#.#.M#.#
#M#..#..
#.######

Output:
YES
5
RRDDR
*/

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define endl "\n"
#define Code_By_Abdelwabab_Emad ios_base::sync_with_stdio(false); cin.tie(0),cout.tie(0);
#define fori(n) for(int i = 0; i < n; i++)
#define forj(n) for(int j = 0; j < n; j++)
#define fork(n) for(int k = 0; k < n; k++)
#define gmx(x, y) ((x) = max((x), (y)))
const int N = 1009;
int dx[] = {1, -1, 0, 0};
int dy[] = {0, 0, 1, -1};
char dir[] = {'D', 'U', 'R', 'L'};
int n, m;
char grid[N][N];
 
bool valid(int i, int j) {
    return (i >= 0 && i < n && j >= 0 && j < m && grid[i][j] != '#');
}
 
void BFS(vector<pair<int, int>>& start, vector<vector<int>>& dis, vector<vector<char>>& op, char target) {
    queue<pair<int, int>> q;
    for (auto& p : start) {
        int x = p.first, y = p.second;
        q.push({x, y});
        dis[x][y] = 0;
    }
    while (!q.empty()) {
        auto [i, j] = q.front();
        q.pop();
        for (int o = 0; o < 4; o++) {
            int ii = i + dx[o], jj = j + dy[o];
            if (valid(ii, jj) && dis[ii][jj] > dis[i][j] + 1) {
                dis[ii][jj] = dis[i][j] + 1;
                q.push({ii, jj});
                if (target == 'A') {
                    op[ii][jj] = dir[o];
                }
            }
        }
    }
}
 
void solve() {
    cin >> n >> m;
    vector<pair<int, int>> monsters, person, source;
    bool flag = false;
 
    fori(n) {
        forj(m) {
            cin >> grid[i][j];
            if ((i == 0 || j == 0 || i == n - 1 || j == m - 1) && grid[i][j] == 'A') {
                flag = true;
            }
            if (grid[i][j] == 'A') person.push_back({i, j});
            if (grid[i][j] == 'M') monsters.push_back({i, j});
            if (grid[i][j] == '.' && (i == 0 || j == 0 || i == n - 1 || j == m - 1)) {
                source.push_back({i, j});
            }
        }
    }
 
    if (flag) {
        cout << "YES" << endl;
        cout << 0;
        return;
    }
 
    vector<vector<char>> op(n, vector<char>(m));
    vector<vector<int>> disA(n, vector<int>(m, INT_MAX)), disM(n, vector<int>(m, INT_MAX));
 
    BFS(person, disA, op, 'A');
    BFS(monsters, disM, op, 'M');
 
    deque<char> path;
    for (auto& [i, j] : source) {
        if (disA[i][j] < disM[i][j]) {
            cout << "YES" << endl <<  disA[i][j] << endl;
            int x = i, y = j;
            while (x != person[0].first || y != person[0].second) {
                path.push_front(op[x][y]);
                if (op[x][y] == 'R') y--;
                else if (op[x][y] == 'L') y++;
                else if (op[x][y] == 'U') x++;
                else x--;
            }
            for (char ch : path) cout << ch;
            return;
        }
    }
    cout << "NO";
}
 
int main() {
    Code_By_Abdelwabab_Emad
    int t = 1;
    while (t--) {
        solve();
    }
    return 0;
}
